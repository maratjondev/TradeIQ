function useClaudeAI() {
  const [messages, setMessages] = useState([
    { role: "assistant", content: "Assalomu alaykum! Men TradeIQ AI — sizning shaxsiy trading yordamchingizman. Bozor tahlili, savdolaringizni ko'rib chiqish yoki trading jurnalingizni tahlil qilish uchun so'rang! 📊" }
  ]);
  const [loading, setLoading] = useState(false);

  const sendMessage = useCallback(async (userMsg, context = "") => {
    const newMessages = [...messages, { role: "user", content: userMsg }];
    setMessages(newMessages);
    setLoading(true);

    try {
      const systemPrompt = `Sen TradeIQ — O'zbekiston va MDH treyderlar uchun yaratilgan AI trading yordamchisan. 
Sen faqat O'zbek tilida javob berasan. 
Qisqa, aniq va foydali javoblar ber.
Trading, kripto bozor, texnik tahlil, risk management haqida maslahat berasan.
Hozirgi bozor konteksti: ${context || "BTC ~$103,240, ETH ~$3,821, umumiy bozor ijobiy"}
Jurnal ma'lumotlari mavjud: 5 ta savdo, 4 ta g'alaba, 1 ta yo'qotish, win rate 80%.
Javobingni 150 so'zdan oshirma. Emoji ishlatishingiz mumkin.`;

      const apiMessages = newMessages.map(m => ({ role: m.role, content: m.content }));

      const res = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "claude-sonnet-4-20250514",
          max_tokens: 1000,
          system: systemPrompt,
          messages: apiMessages,
        }),
      });

      const data = await res.json();
      const reply = data.content?.[0]?.text || "Uzr, javob olishda xatolik yuz berdi. Qaytadan urinib ko'ring.";
      setMessages(prev => [...prev, { role: "assistant", content: reply }]);
    } catch {
      setMessages(prev => [...prev, { role: "assistant", content: "Internet aloqasida muammo bor. Qaytadan urinib ko'ring. 🔄" }]);
    } finally {
      setLoading(false);
    }
  }, [messages]);

  return { messages, loading, sendMessage };
}

