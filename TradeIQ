// ============================================================
function MiniChart({ positive, width = 80, height = 36 }) {
  const pts = positive
    ? [0, 28, 8, 24, 16, 26, 24, 18, 32, 20, 40, 12, 48, 14, 56, 8, 64, 10, 72, 4, 80, 6]
    : [0, 6, 8, 10, 16, 8, 24, 16, 32, 14, 40, 22, 48, 18, 56, 26, 64, 22, 72, 28, 80, 32];
  const color = positive ? "#00e99a" : "#ff4d6d";
  const polyStr = pts.reduce((a, v, i) => a + (i % 2 === 0 ? (i ? " " : "") + v : "," + v), "");
  const areaStr = `0,${height} ` + polyStr + ` ${width},${height}`;
  return (
    <svg width={width} height={height} viewBox={`0 0 ${width} ${height}`}>
      <defs>
        <linearGradient id={`mg${positive}`} x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stopColor={color} stopOpacity="0.25" />
          <stop offset="100%" stopColor={color} stopOpacity="0" />
        </linearGradient>
      </defs>
      <polygon points={areaStr} fill={`url(#mg${positive})`} />
      <polyline points={polyStr} fill="none" stroke={color} strokeWidth="2" strokeLinejoin="round" />
    </svg>
  );
}

