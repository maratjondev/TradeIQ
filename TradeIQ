            { key:"binance", label:"Binance API Key", hint:"binance.com → API Management" },
            { key:"bybit", label:"Bybit API Key", hint:"bybit.com → API" },
            { key:"okx", label:"OKX API Key", hint:"okx.com → API Keys" },
            { key:"claude", label:"Claude (Anthropic) API Key", hint:"console.anthropic.com → API Keys" },
          ].map(({key,label,hint}) => (
            <div key={key}>
              <div style={{ display:"flex", justifyContent:"space-between", marginBottom:6 }}>
                <label style={{ fontFamily:"'Syne',sans-serif", fontSize:12, fontWeight:600 }}>{label}</label>
                <span style={{ fontFamily:"'JetBrains Mono',monospace", fontSize:10, color:t.sub }}>{hint}</span>
              </div>
              <input type="password" placeholder="sk-..." value={apiKeys[key]} onChange={e=>setApiKeys(p=>({...p,[key]:e.target.value}))} />
            </div>
          ))}
          <button className="btn-primary" style={{ marginTop:8, display:"flex", alignItems:"center", justifyContent:"center", gap:6 }}>
            <Icon name="key" size={14} /> Saqlash
          </button>
        </div>
      </div>
    </div>
  );

  const pages = { dashboard:<Dashboard/>, prices:<PricesPage/>, portfolio:<PortfolioPage/>, ai:<AiPage/>, journal:<JournalPage/>, arbitrage:<ArbitragePage/>, settings:<SettingsPage/> };

  return (
    <div style={{ fontFamily:"'Syne',sans-serif", background:t.bg, minHeight:"100vh", color:t.text, display:"flex" }}>
      <style>{css}</style>

      {/* SIDEBAR */}
      <div style={{ width:220, background:t.sidebar, borderRight:`1px solid ${t.border}`, display:"flex", flexDirection:"column", position:"fixed", top:0, left:sideOpen?0:-220, height:"100vh", zIndex:100, transition:"left 0.3s cubic-bezier(0.4,0,0.2,1)", boxShadow:sideOpen?`4px 0 32px rgba(0,0,0,0.4)`:"none" }}>
        {/* Logo */}
        <div style={{ padding:"20px 18px", borderBottom:`1px solid ${t.border}` }}>
          <div style={{ display:"flex", alignItems:"center", justifyContent:"space-between" }}>
            <div style={{ display:"flex", alignItems:"center", gap:10 }}>
              <div style={{ width:38, height:38, background:`linear-gradient(135deg,${t.accent},${t.blue})`, borderRadius:11, display:"flex", alignItems:"center", justifyContent:"center", fontSize:18 }}>◈</div>
              <div>
                <div style={{ fontSize:16, fontWeight:800, letterSpacing:1 }}>TradeIQ</div>
                <div style={{ fontSize:9, color:t.sub, letterSpacing:2 }}>O'ZBEK TILI</div>
              </div>
            </div>
            <button onClick={()=>setSideOpen(false)} style={{ background:"none", border:"none", color:t.sub, cursor:"pointer" }}>
              <Icon name="close" size={16} />
            </button>
          </div>
        </div>

        {/* Nav */}
        <div style={{ flex:1, padding:"12px 10px", overflowY:"auto" }}>
          {navItems.map(item => (
            <button key={item.id} onClick={()=>{setPage(item.id);setSideOpen(false);}} className="nav-item"
              style={{ width:"100%", display:"flex", alignItems:"center", gap:11, padding:"11px 12px", borderRadius:10, cursor:"pointer", marginBottom:3, background:page===item.id?`${t.accent}15`:"transparent", borderLeft:page===item.id?`2px solid ${t.accent}`:"2px solid transparent", color:page===item.id?t.accent:t.sub, fontSize:13, fontWeight:page===item.id?700:500, border:"none", textAlign:"left", transition:"all 0.2s", fontFamily:"'Syne',sans-serif" }}>
              <Icon name={item.icon} size={16} />
              <span>{item.label}</span>
              {item.soon && <span style={{ fontSize:9, background:t.purple+"33", color:t.purple, padding:"2px 6px", borderRadius:4, marginLeft:"auto", fontWeight:700 }}>BREVE</span>}
            </button>
          ))}
        </div>

        {/* Bottom */}
        <div style={{ padding:"12px 10px", borderTop:`1px solid ${t.border}` }}>
          <button onClick={()=>{setPage("settings");setSideOpen(false);}} className="nav-item"
            style={{ width:"100%", display:"flex", alignItems:"center", gap:11, padding:"11px 12px", borderRadius:10, cursor:"pointer", background:page==="settings"?`${t.accent}15`:"transparent", borderLeft:page==="settings"?`2px solid ${t.accent}`:"2px solid transparent", color:page==="settings"?t.accent:t.sub, fontSize:13, fontWeight:500, border:"none", textAlign:"left", transition:"all 0.2s", fontFamily:"'Syne',sans-serif" }}>
            <Icon name="settings" size={16} />
            <span>Sozlamalar</span>
          </button>
          <div style={{ display:"flex", alignItems:"center", gap:10, padding:"11px 12px", marginTop:4 }}>
            <div style={{ width:32, height:32, background:`linear-gradient(135deg,${t.purple},${t.blue})`, borderRadius:"50%", display:"flex", alignItems:"center", justifyContent:"center", fontSize:13 }}>👤</div>
            <div>
              <div style={{ fontSize:12, fontWeight:700 }}>Trader</div>
              <div style={{ fontSize:10, color:t.accent }}>● Online</div>
            </div>
          </div>
        </div>
      </div>

      {/* Overlay */}
      {sideOpen && <div onClick={()=>setSideOpen(false)} style={{ position:"fixed", inset:0, background:"rgba(0,0,0,0.6)", zIndex:99, backdropFilter:"blur(2px)" }} />}

      {/* MAIN */}
      <div style={{ flex:1, display:"flex", flexDirection:"column" }}>
        {/* TOPBAR */}
        <div style={{ background:t.sidebar, borderBottom:`1px solid ${t.border}`, padding:"12px 16px", display:"flex", alignItems:"center", gap:12, position:"sticky", top:0, zIndex:50 }}>
          <button onClick={()=>setSideOpen(true)} style={{ background:"none", border:"none", color:t.text, cursor:"pointer", padding:4, display:"flex" }}>
            <Icon name="menu" size={22} />
          </button>

          <div style={{ flex:1 }}>
            <div style={{ fontWeight:800, fontSize:15 }}>{navItems.find(n=>n.id===page)?.label || "Sozlamalar"}</div>
            <div style={{ fontSize:10, color:t.sub }}>4 birja ulangan • Real-time</div>
          </div>

          {/* BTC quick */}
          <div style={{ display:"flex", alignItems:"center", gap:6, padding:"6px 12px", background:t.card2, borderRadius:10, border:`1px solid ${t.border}` }}>
            <span style={{ fontSize:12, color:"#F7931A" }}>₿</span>
            <span style={{ fontFamily:"'JetBrains Mono',monospace", fontSize:12, fontWeight:600 }}>${fmt(prices.BTC.mexc)}</span>
            <span style={{ fontSize:10, color:t.accent }}>▲2.4%</span>
          </div>

          {/* Live */}
          <div style={{ display:"flex", alignItems:"center", gap:5, background:t.accent+"15", border:`1px solid ${t.accent}30`, borderRadius:20, padding:"5px 11px" }}>
            <div className="live-dot" style={{ width:6, height:6, borderRadius:"50%", background:t.accent }} />
            <span style={{ fontSize:11, color:t.accent, fontWeight:700 }}>JONLI</span>
          </div>

          {/* Theme */}
          <button onClick={()=>setDark(!dark)} style={{ background:t.card2, border:`1px solid ${t.border}`, borderRadius:10, padding:"7px 12px", cursor:"pointer", color:t.text, display:"flex", alignItems:"center", gap:6, fontSize:12, fontFamily:"'Syne',sans-serif", fontWeight:600 }}>
            {dark ? <><Icon name="sun" size={14} /> Yorug'</> : <><Icon name="moon" size={14} /> Qorong'u</>}
          </button>
        </div>

        {/* PAGE CONTENT */}
        <div style={{ flex:1, padding:"16px 16px 32px", maxWidth:960, margin:"0 auto", width:"100%" }}>
          {pages[page] || <Dashboard />}
        </div>
      </div>

      {/* ADD TRADE MODAL */}
      {showAddTrade && (
        <div className="modal-bg" onClick={e=>e.target===e.currentTarget&&setShowAddTrade(false)}>
          <div className="modal fade">
            <div style={{ display:"flex", justifyContent:"space-between", marginBottom:20 }}>
              <div style={{ fontSize:16, fontWeight:800 }}>Yangi Savdo Qo'shish</div>
              <button onClick={()=>setShowAddTrade(false)} style={{ background:"none", border:"none", color:t.sub, cursor:"pointer" }}><Icon name="close" size:18 /></button>
            </div>
            <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr", gap:12 }}>
              {[
                { l:"Juftlik", key:"pair", type:"select", opts:["BTC/USDT","ETH/USDT","SOL/USDT","BNB/USDT","XRP/USDT"] },
                { l:"Tur", key:"type", type:"select", opts:["LONG","SHORT"] },
                { l:"Leverage", key:"leverage", type:"select", opts:["1x","2x","3x","5x","8x","10x","20x","50x"] },
                { l:"Hajm ($)", key:"size", type:"number", ph:"1000" },
                { l:"Kirish narxi", key:"entry", type:"number", ph:"103000" },
                { l:"Chiqish narxi", key:"exit", type:"number", ph:"104000" },
              ].map(f => (
                <div key={f.key}>
                  <label style={{ fontSize:11, color:t.sub, marginBottom:5, display:"block", fontWeight:600 }}>{f.l}</label>
                  {f.type==="select" ? (
                    <select value={newTrade[f.key]} onChange={e=>setNewTrade(p=>({...p,[f.key]:e.target.value}))}>
                      {f.opts.map(o=><option key={o}>{o}</option>)}
                    </select>
                  ) : (
                    <input type="number" placeholder={f.ph} value={newTrade[f.key]} onChange={e=>setNewTrade(p=>({...p,[f.key]:e.target.value}))} />
                  )}
                </div>
              ))}
              <div style={{ gridColumn:"1/-1" }}>
                <label style={{ fontSize:11, color:t.sub, marginBottom:5, display:"block", fontWeight:600 }}>Izoh</label>
                <textarea rows={2} placeholder="Savdo strategiyasi..." value={newTrade.note} onChange={e=>setNewTrade(p=>({...p,note:e.target.value}))} style={{ resize:"none" }} />
              </div>
            </div>
            <div style={{ display:"flex", gap:10, marginTop:20 }}>
              <button className="btn-ghost" onClick={()=>setShowAddTrade(false)} style={{ flex:1 }}>Bekor</button>
              <button className="btn-primary" onClick={addTrade} style={{ flex:2 }}>✓ Qo'shish</button>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}
